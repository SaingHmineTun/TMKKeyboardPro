<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#1A1A1A"
    android:padding="1dp">

    <Button
        android:id="@+id/key_1"
        style="@style/TmkKeyStyle"
        android:text="1"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@+id/key_2"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/key_2"
        style="@style/TmkKeyStyle"
        android:text="2"
        app:layout_constraintBottom_toBottomOf="@id/key_1"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_1"
        app:layout_constraintRight_toLeftOf="@+id/key_3"
        app:layout_constraintTop_toTopOf="@id/key_1" />

    <Button
        android:id="@+id/key_3"
        style="@style/TmkKeyStyle"
        android:text="3"
        app:layout_constraintBottom_toBottomOf="@id/key_1"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_2"
        app:layout_constraintRight_toLeftOf="@+id/key_4"
        app:layout_constraintTop_toTopOf="@id/key_1" />

    <Button
        android:id="@+id/key_4"
        style="@style/TmkKeyStyle"
        android:text="4"
        app:layout_constraintBottom_toBottomOf="@id/key_1"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_3"
        app:layout_constraintRight_toLeftOf="@+id/key_5"
        app:layout_constraintTop_toTopOf="@id/key_1" />

    <Button
        android:id="@+id/key_5"
        style="@style/TmkKeyStyle"
        android:text="5"
        app:layout_constraintBottom_toBottomOf="@id/key_1"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_4"
        app:layout_constraintRight_toLeftOf="@+id/key_6"
        app:layout_constraintTop_toTopOf="@id/key_1" />

    <Button
        android:id="@+id/key_6"
        style="@style/TmkKeyStyle"
        android:text="6"
        app:layout_constraintBottom_toBottomOf="@id/key_1"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_5"
        app:layout_constraintRight_toLeftOf="@+id/key_7"
        app:layout_constraintTop_toTopOf="@id/key_1" />

    <Button
        android:id="@+id/key_7"
        style="@style/TmkKeyStyle"
        android:text="7"
        app:layout_constraintBottom_toBottomOf="@id/key_1"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_6"
        app:layout_constraintRight_toLeftOf="@+id/key_8"
        app:layout_constraintTop_toTopOf="@id/key_1" />

    <Button
        android:id="@+id/key_8"
        style="@style/TmkKeyStyle"
        android:text="8"
        app:layout_constraintBottom_toBottomOf="@id/key_1"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_7"
        app:layout_constraintRight_toLeftOf="@+id/key_9"
        app:layout_constraintTop_toTopOf="@id/key_1" />

    <Button
        android:id="@+id/key_9"
        style="@style/TmkKeyStyle"
        android:text="9"
        app:layout_constraintBottom_toBottomOf="@id/key_1"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_8"
        app:layout_constraintRight_toLeftOf="@+id/key_0"
        app:layout_constraintTop_toTopOf="@id/key_1" />

    <Button
        android:id="@+id/key_0"
        style="@style/TmkKeyStyle"
        android:text="0"
        app:layout_constraintBottom_toBottomOf="@id/key_1"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_9"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="@id/key_1" />

    <Button
        android:id="@+id/key_tilde"
        style="@style/TmkKeyStyle"
        android:text="~"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@+id/key_grave"
        app:layout_constraintTop_toBottomOf="@+id/key_1" />

    <Button
        android:id="@+id/key_grave"
        style="@style/TmkKeyStyle"
        android:text="`"
        app:layout_constraintBottom_toBottomOf="@id/key_tilde"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_tilde"
        app:layout_constraintRight_toLeftOf="@+id/key_pipe"
        app:layout_constraintTop_toTopOf="@+id/key_tilde"

        />

    <Button
        android:id="@+id/key_pipe"
        style="@style/TmkKeyStyle"
        android:text="|"
        app:layout_constraintBottom_toBottomOf="@id/key_tilde"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_grave"
        app:layout_constraintRight_toLeftOf="@+id/key_bullet"
        app:layout_constraintTop_toTopOf="@+id/key_tilde" />

    <Button
        android:id="@+id/key_bullet"
        style="@style/TmkKeyStyle"
        android:text="•"
        app:layout_constraintBottom_toBottomOf="@id/key_tilde"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_pipe"
        app:layout_constraintRight_toLeftOf="@+id/key_sqrt"
        app:layout_constraintTop_toTopOf="@+id/key_tilde" />

    <Button
        android:id="@+id/key_sqrt"
        style="@style/TmkKeyStyle"
        android:text="√"
        app:layout_constraintBottom_toBottomOf="@id/key_tilde"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_bullet"
        app:layout_constraintRight_toLeftOf="@+id/key_pi"
        app:layout_constraintTop_toTopOf="@+id/key_tilde" />

    <Button
        android:id="@+id/key_pi"
        style="@style/TmkKeyStyle"
        android:text="π"
        app:layout_constraintBottom_toBottomOf="@id/key_tilde"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_sqrt"
        app:layout_constraintRight_toLeftOf="@+id/key_divide"
        app:layout_constraintTop_toTopOf="@+id/key_tilde" />

    <Button
        android:id="@+id/key_divide"
        style="@style/TmkKeyStyle"
        android:text="÷"
        app:layout_constraintBottom_toBottomOf="@id/key_tilde"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_pi"
        app:layout_constraintRight_toLeftOf="@+id/key_multiply"
        app:layout_constraintTop_toTopOf="@+id/key_tilde" />

    <Button
        android:id="@+id/key_multiply"
        style="@style/TmkKeyStyle"
        android:text="×"
        app:layout_constraintBottom_toBottomOf="@id/key_tilde"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_divide"
        app:layout_constraintRight_toLeftOf="@+id/key_paragraph"
        app:layout_constraintTop_toTopOf="@+id/key_tilde" />

    <Button
        android:id="@+id/key_paragraph"
        style="@style/TmkKeyStyle"
        android:text="¶"
        app:layout_constraintBottom_toBottomOf="@id/key_tilde"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_multiply"
        app:layout_constraintRight_toLeftOf="@+id/key_delta"
        app:layout_constraintTop_toTopOf="@+id/key_tilde" />

    <Button
        android:id="@+id/key_delta"
        style="@style/TmkKeyStyle"
        android:text="∆"
        app:layout_constraintBottom_toBottomOf="@id/key_tilde"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_paragraph"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="@+id/key_tilde" />

    <Button
        android:id="@+id/key_curly_open"
        style="@style/TmkKeyStyle"
        android:text="{"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@+id/key_curly_close"
        app:layout_constraintTop_toBottomOf="@+id/key_tilde" />

    <Button
        android:id="@+id/key_curly_close"
        style="@style/TmkKeyStyle"
        android:text="}"
        app:layout_constraintBottom_toBottomOf="@id/key_curly_open"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_curly_open"
        app:layout_constraintRight_toLeftOf="@+id/key_sq_bracket_open"
        app:layout_constraintTop_toTopOf="@+id/key_curly_open" />

    <Button
        android:id="@+id/key_sq_bracket_open"
        style="@style/TmkKeyStyle"
        android:text="["
        app:layout_constraintBottom_toBottomOf="@id/key_curly_open"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_curly_close"
        app:layout_constraintRight_toLeftOf="@+id/key_sq_bracket_close"
        app:layout_constraintTop_toTopOf="@+id/key_curly_open" />

    <Button
        android:id="@+id/key_sq_bracket_close"
        style="@style/TmkKeyStyle"
        android:text="]"
        app:layout_constraintBottom_toBottomOf="@id/key_curly_open"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_sq_bracket_open"
        app:layout_constraintRight_toLeftOf="@+id/key_angle_open"
        app:layout_constraintTop_toTopOf="@+id/key_curly_open" />

    <Button
        android:id="@+id/key_angle_open"
        style="@style/TmkKeyStyle"
        android:text="&lt;"
        app:layout_constraintBottom_toBottomOf="@id/key_curly_open"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_sq_bracket_close"
        app:layout_constraintRight_toLeftOf="@+id/key_angle_close"
        app:layout_constraintTop_toTopOf="@+id/key_curly_open" />

    <Button
        android:id="@+id/key_angle_close"
        style="@style/TmkKeyStyle"
        android:text="&gt;"
        app:layout_constraintBottom_toBottomOf="@id/key_curly_open"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_angle_open"
        app:layout_constraintRight_toLeftOf="@+id/key_euro"
        app:layout_constraintTop_toTopOf="@+id/key_curly_open" />

    <Button
        android:id="@+id/key_euro"
        style="@style/TmkKeyStyle"
        android:text="€"
        app:layout_constraintBottom_toBottomOf="@id/key_curly_open"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_angle_close"
        app:layout_constraintRight_toLeftOf="@+id/key_pound"
        app:layout_constraintTop_toTopOf="@+id/key_curly_open" />

    <Button
        android:id="@+id/key_pound"
        style="@style/TmkKeyStyle"
        android:text="£"
        app:layout_constraintBottom_toBottomOf="@id/key_curly_open"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_euro"
        app:layout_constraintRight_toLeftOf="@+id/key_yen"
        app:layout_constraintTop_toTopOf="@+id/key_curly_open" />

    <Button
        android:id="@+id/key_yen"
        style="@style/TmkKeyStyle"
        android:text="¥"
        app:layout_constraintBottom_toBottomOf="@id/key_curly_open"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_pound"
        app:layout_constraintRight_toLeftOf="@+id/key_won"
        app:layout_constraintTop_toTopOf="@+id/key_curly_open" />

    <Button
        android:id="@+id/key_won"
        style="@style/TmkKeyStyle"
        android:text="₩"
        app:layout_constraintBottom_toBottomOf="@id/key_curly_open"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_yen"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="@+id/key_curly_open" />

    <Button
        android:id="@+id/key_copyright"
        style="@style/TmkKeyStyle"
        android:text="©"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@+id/key_registered"
        app:layout_constraintTop_toBottomOf="@+id/key_curly_open" />

    <Button
        android:id="@+id/key_registered"
        style="@style/TmkKeyStyle"
        android:text="®"
        app:layout_constraintBottom_toBottomOf="@id/key_copyright"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_copyright"
        app:layout_constraintRight_toLeftOf="@+id/key_trademark"
        app:layout_constraintTop_toTopOf="@+id/key_copyright" />

    <Button
        android:id="@+id/key_trademark"
        style="@style/TmkKeyStyle"
        android:text="™"
        app:layout_constraintBottom_toBottomOf="@id/key_copyright"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_registered"
        app:layout_constraintRight_toLeftOf="@+id/key_degree"
        app:layout_constraintTop_toTopOf="@+id/key_copyright" />

    <Button
        android:id="@+id/key_degree"
        style="@style/TmkKeyStyle"
        android:text="°"
        app:layout_constraintBottom_toBottomOf="@id/key_copyright"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_trademark"
        app:layout_constraintRight_toLeftOf="@+id/key_backslash"
        app:layout_constraintTop_toTopOf="@+id/key_copyright" />

    <Button
        android:id="@+id/key_backslash"
        style="@style/TmkKeyStyle"
        android:text="\\"
        app:layout_constraintBottom_toBottomOf="@id/key_copyright"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_degree"
        app:layout_constraintRight_toLeftOf="@+id/key_degree_cel"
        app:layout_constraintTop_toTopOf="@+id/key_copyright" />

    <Button
        android:id="@+id/key_degree_cel"
        style="@style/TmkKeyStyle"
        android:text="℃"
        app:layout_constraintBottom_toBottomOf="@id/key_copyright"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_backslash"
        app:layout_constraintRight_toLeftOf="@+id/key_infinity"
        app:layout_constraintTop_toTopOf="@+id/key_copyright" />

    <Button
        android:id="@+id/key_infinity"
        style="@style/TmkKeyStyle"
        android:text="∞"
        app:layout_constraintBottom_toBottomOf="@id/key_copyright"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_degree_cel"
        app:layout_constraintRight_toLeftOf="@+id/key_approx"
        app:layout_constraintTop_toTopOf="@+id/key_copyright" />

    <Button
        android:id="@+id/key_approx"
        style="@style/TmkKeyStyle"
        android:text="≈"
        app:layout_constraintBottom_toBottomOf="@id/key_copyright"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_infinity"
        app:layout_constraintRight_toLeftOf="@+id/key_not_equal"
        app:layout_constraintTop_toTopOf="@+id/key_copyright" />

    <Button
        android:id="@+id/key_not_equal"
        style="@style/TmkKeyStyle"
        android:text="≠"
        app:layout_constraintBottom_toBottomOf="@id/key_copyright"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_approx"
        app:layout_constraintRight_toLeftOf="@+id/key_del"
        app:layout_constraintTop_toTopOf="@+id/key_copyright" />

    <Button
        android:id="@+id/key_del"
        style="@style/ActionTmkKeyStyle"
        android:text="⌫"
        app:layout_constraintBottom_toBottomOf="@id/key_copyright"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_not_equal"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="@+id/key_copyright" />

    <Button
        android:id="@+id/key_switch_abc"
        style="@style/ActionTmkKeyStyle"
        android:text="ABC"
        app:layout_constraintHorizontal_weight="1.5"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@+id/key_2_1"
        app:layout_constraintTop_toBottomOf="@+id/key_copyright" />

    <Button
        android:id="@+id/key_2_1"
        style="@style/ActionTmkKeyStyle"
        android:text="\?123"
        app:layout_constraintBottom_toBottomOf="@id/key_switch_abc"
        app:layout_constraintHorizontal_weight="1.5"
        app:layout_constraintLeft_toRightOf="@+id/key_switch_abc"
        app:layout_constraintRight_toLeftOf="@+id/key_comma"
        app:layout_constraintTop_toTopOf="@+id/key_switch_abc" />

    <Button
        android:id="@+id/key_comma"
        style="@style/ActionTmkKeyStyle"
        android:text=","
        app:layout_constraintBottom_toBottomOf="@id/key_switch_abc"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_2_1"
        app:layout_constraintRight_toLeftOf="@+id/key_space"
        app:layout_constraintTop_toTopOf="@+id/key_switch_abc" />

    <Button
        android:id="@+id/key_space"
        style="@style/TmkKeyStyle"
        android:text="Space"
        app:layout_constraintBottom_toBottomOf="@id/key_switch_abc"
        app:layout_constraintHorizontal_weight="3.5"
        app:layout_constraintLeft_toRightOf="@+id/key_comma"
        app:layout_constraintRight_toLeftOf="@+id/key_period"
        app:layout_constraintTop_toTopOf="@+id/key_switch_abc" />

    <Button
        android:id="@+id/key_period"
        style="@style/ActionTmkKeyStyle"
        android:text="."
        app:layout_constraintBottom_toBottomOf="@id/key_switch_abc"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintLeft_toRightOf="@+id/key_space"
        app:layout_constraintRight_toLeftOf="@+id/key_enter"
        app:layout_constraintTop_toTopOf="@+id/key_switch_abc" />

    <Button
        android:id="@+id/key_enter"
        style="@style/ActionTmkKeyStyle"
        android:text="⏎"
        app:layout_constraintBottom_toBottomOf="@id/key_switch_abc"
        app:layout_constraintHorizontal_weight="1.5"
        app:layout_constraintLeft_toRightOf="@+id/key_period"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="@+id/key_switch_abc" />

</androidx.constraintlayout.widget.ConstraintLayout>